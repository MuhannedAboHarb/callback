modules = ["nodejs-20", "web", "php-8.2"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_NAME = "Laravel"
APP_ENV = "local"
APP_DEBUG = "true"
APP_URL = "http://localhost"
LOG_CHANNEL = "stack"
LOG_LEVEL = "debug"
DB_CONNECTION = "pgsql"
DB_HOST = "helium"
DB_PORT = "5432"
DB_DATABASE = "heliumdb"
DB_USERNAME = "postgres"
BROADCAST_DRIVER = "log"
CACHE_DRIVER = "file"
FILESYSTEM_DISK = "local"
QUEUE_CONNECTION = "sync"
SESSION_DRIVER = "file"
SESSION_LIFETIME = "120"
MAIL_MAILER = "log"
MAIL_FROM_ADDRESS = "hello@example.com"
MAIL_FROM_NAME = "Laravel"
DB_PASSWORD = "password"
APP_KEY = "base64:HdV6C64HREBFlJi+XEu/qgxLxLhMfkEqwt+kgTkKw1c="

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "start.sh"]
build = ["bash", "-c", "composer install --no-dev --optimize-autoloader && npm install && npm run build"]
